POSTGRES_DB=autoqa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password

DATABASE_URL=postgresql+psycopg://postgres:change-this-postgres-password@postgres:5432/autoqa
REDIS_URL=redis://redis:6379/0

API_PUBLIC_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

ARTIFACTS_ROOT=/workspace/artifacts
GENERATED_TESTS_ROOT=/workspace/generated-tests

PLAYWRIGHT_HEADLESS=true
SAFE_MODE_DEFAULT=true
WORKER_QUEUE_NAME=autoqa:runs
WORKER_POLL_TIMEOUT=3
